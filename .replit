modules = ["nodejs-20", "web", "bash", "python-3.11", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-25_05"
packages = ["imagemagick", "pandoc", "postgresql", "tesseract"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 23636
externalPort = 3000

[[ports]]
localPort = 23637
externalPort = 3001

[[ports]]
localPort = 23638
externalPort = 3002

[[ports]]
localPort = 23639
externalPort = 4200

[[ports]]
localPort = 23640
externalPort = 3003

[env]
PORT = "5000"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "fk-names"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "fk-names"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx scripts/check-fk-names.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/run-template-tests.sh"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/check-tsc-baseline.sh"

[agent]
integrations = ["javascript_auth_all_persistance:1.0.0", "javascript_log_in_with_replit:1.0.0", "javascript_database:1.0.0", "javascript_openai:1.0.0", "javascript_object_storage:1.0.0", "resend:1.0.0", "javascript_anthropic_ai_integrations:2.0.0"]
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 240000
